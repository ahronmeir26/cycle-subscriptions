{% comment %}
  Storefront subscription widget.

  Renders the product's selling plan groups (the recurring shirt program) as
  radio options alongside a one-time purchase option, and surfaces the
  milestone reward message the merchant configures in the theme editor.

  The selected selling plan id is synced into a hidden `selling_plan` input
  inside the nearest product form, which the theme submits to /cart/add.
{% endcomment %}

{%- assign has_plans = false -%}
{%- if product.selling_plan_groups.size > 0 -%}
  {%- assign has_plans = true -%}
{%- endif -%}

<div
  class="subscription-widget"
  data-product-id="{{ product.id }}"
  {{ block.shopify_attributes }}
>
  <p class="subscription-widget__heading">
    {{ block.settings.heading | default: 'subscription_widget.heading' | t }}
  </p>

  {%- if block.settings.reward_text != blank -%}
    <p class="subscription-widget__reward">
      <span class="subscription-widget__reward-badge">
        {{ 'subscription_widget.reward_prefix' | t }}
      </span>
      {{ block.settings.reward_text }}
    </p>
  {%- endif -%}

  {%- if has_plans -%}
    <fieldset class="subscription-widget__options">
      {%- if block.settings.show_one_time -%}
        <label class="subscription-widget__option">
          <input
            type="radio"
            name="subscription_widget_plan"
            value=""
            checked
          >
          <span class="subscription-widget__option-label">
            {{ 'subscription_widget.one_time' | t }}
          </span>
        </label>
      {%- endif -%}

      {%- for group in product.selling_plan_groups -%}
        {%- for plan in group.selling_plans -%}
          <label class="subscription-widget__option">
            <input
              type="radio"
              name="subscription_widget_plan"
              value="{{ plan.id }}"
              {% unless block.settings.show_one_time %}{% if forloop.first and forloop.parentloop.first %}checked{% endif %}{% endunless %}
            >
            <span class="subscription-widget__option-label">
              {{ plan.name }}
              {%- if plan.price_adjustments.size > 0 -%}
                {%- assign adjustment = plan.price_adjustments.first -%}
                {%- if adjustment.value_type == 'percentage' -%}
                  <span class="subscription-widget__save">
                    Save {{ adjustment.value }}%
                  </span>
                {%- endif -%}
              {%- endif -%}
            </span>
          </label>
        {%- endfor -%}
      {%- endfor -%}
    </fieldset>
  {%- else -%}
    <p class="subscription-widget__empty">
      {{ 'subscription_widget.no_plans' | t }}
    </p>
  {%- endif -%}
</div>

{% javascript %}
  (function () {
    document.querySelectorAll('.subscription-widget').forEach(function (widget) {
      if (widget.dataset.bound === 'true') return;
      widget.dataset.bound = 'true';

      var form =
        widget.closest('form[action*="/cart/add"]') ||
        document.querySelector('form[action*="/cart/add"]');
      if (!form) return;

      function syncHidden(value) {
        var hidden = form.querySelector('input[name="selling_plan"]');
        if (!hidden) {
          hidden = document.createElement('input');
          hidden.type = 'hidden';
          hidden.name = 'selling_plan';
          form.appendChild(hidden);
        }
        hidden.value = value || '';
        hidden.disabled = !value;
      }

      widget.addEventListener('change', function (event) {
        var target = event.target;
        if (target && target.name === 'subscription_widget_plan') {
          syncHidden(target.value);
        }
      });

      var checked = widget.querySelector(
        'input[name="subscription_widget_plan"]:checked',
      );
      if (checked) syncHidden(checked.value);
    });
  })();
{% endjavascript %}

{% stylesheet %}
  .subscription-widget {
    border: 1px solid rgba(18, 37, 48, 0.14);
    border-radius: 12px;
    padding: 1rem 1.15rem;
    margin: 1rem 0;
    display: grid;
    gap: 0.65rem;
  }

  .subscription-widget__heading {
    margin: 0;
    font-weight: 700;
    font-size: 1rem;
  }

  .subscription-widget__reward {
    margin: 0;
    font-size: 0.9rem;
    color: #24333d;
  }

  .subscription-widget__reward-badge {
    display: inline-block;
    background: #eaf7f0;
    color: #006b42;
    border-radius: 999px;
    padding: 0.1rem 0.55rem;
    font-weight: 700;
    font-size: 0.78rem;
    margin-right: 0.35rem;
  }

  .subscription-widget__options {
    border: 0;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }

  .subscription-widget__option {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    border: 1px solid rgba(18, 37, 48, 0.14);
    border-radius: 8px;
    padding: 0.6rem 0.75rem;
    cursor: pointer;
  }

  .subscription-widget__option:has(input:checked) {
    border-color: #006b42;
    background: rgba(0, 107, 66, 0.05);
  }

  .subscription-widget__save {
    color: #006b42;
    font-weight: 700;
    font-size: 0.82rem;
    margin-left: 0.35rem;
  }

  .subscription-widget__empty {
    margin: 0;
    color: #62707c;
    font-size: 0.88rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Subscription widget",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Subscribe & save"
    },
    {
      "type": "textarea",
      "id": "reward_text",
      "label": "Reward message",
      "info": "Explain the milestone perk, e.g. the free shipment on the 12th paid cycle.",
      "default": "Every 12th shipment ships free."
    },
    {
      "type": "checkbox",
      "id": "show_one_time",
      "label": "Show one-time purchase option",
      "default": true
    }
  ]
}
{% endschema %}
