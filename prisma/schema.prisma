// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model SubscriptionProgram {
  id                 String                @id @default(cuid())
  shop               String
  name               String                @default("Shirt replenishment")
  status             String                @default("draft")
  shirtQuantity      Int                   @default(2)
  intervalMonths     Int                   @default(2)
  freeEveryCycles    Int                   @default(12)
  productGids        String                @default("")
  sellingPlanGroupId String?
  sellingPlanId      String?
  notifyRewards      Boolean               @default(true)
  autoSyncSellingPlan Boolean              @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  accounts           SubscriptionAccount[]
  events             SubscriptionEvent[]

  @@index([shop])
}

model SubscriptionAccount {
  id              String              @id @default(cuid())
  shop            String
  programId       String?
  customerId      String?
  customerEmail   String?
  contractId      String?
  paidCycles      Int                 @default(0)
  nextRewardCycle Int                 @default(12)
  status          String              @default("active")
  lastOrderId     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  program         SubscriptionProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  events          SubscriptionEvent[]

  @@index([shop])
  @@index([programId])
  @@index([contractId])
  @@index([customerId])
}

model SubscriptionEvent {
  id          String               @id @default(cuid())
  shop        String
  programId   String?
  accountId   String?
  type        String
  orderId     String?
  cycleNumber Int?
  note        String?
  createdAt   DateTime             @default(now())
  program     SubscriptionProgram?  @relation(fields: [programId], references: [id], onDelete: SetNull)
  account     SubscriptionAccount?  @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([shop])
  @@index([programId])
  @@index([accountId])
  @@index([type])
}
