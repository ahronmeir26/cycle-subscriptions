SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Compatibility aliases used by Shopify's Node libraries and CLI.
# Paste the same values as SHOPIFY_CLIENT_ID and SHOPIFY_CLIENT_SECRET if the CLI asks for these names.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

SHOPIFY_APP_URL=https://cycle-subs.aistone.com
SCOPES=write_products,read_orders,read_customers,read_own_subscription_contracts,write_own_subscription_contracts
DATABASE_URL="postgresql://subscriptions_user:replace-me@127.0.0.1:5432/shirt_subscriptions?schema=public"
NODE_ENV=development
